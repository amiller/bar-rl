diff --git a/FPUSettings.h b/FPUSettings.h
index 5883b36..d49817c 100644
--- a/FPUSettings.h
+++ b/FPUSettings.h
@@ -218,7 +218,15 @@ enum FPU_RoundMode {
 */
 
 // plan for portability
-#if defined(_MSC_VER)
+#if defined(__EMSCRIPTEN__) || defined(__wasm__)
+// WASM has no FPU control word. IEEE 754 is the WASM float semantics by spec —
+// rounding mode is round-to-nearest-even, no denorm flushing. These become
+// no-ops that zero their output; streflop's FE_* masks are purely informational.
+#define STREFLOP_FSTCW(cw)   do { (cw) = 0; } while (0)
+#define STREFLOP_FLDCW(cw)   do { (void)(cw); } while (0)
+#define STREFLOP_STMXCSR(cw) do { (cw) = 0; } while (0)
+#define STREFLOP_LDMXCSR(cw) do { (void)(cw); } while (0)
+#elif defined(_MSC_VER)
 #ifdef _M_IX86
 #define STREFLOP_FSTCW(cw) do { short tmp; __asm { fstcw tmp }; (cw) = tmp; } while (0)
 #define STREFLOP_FLDCW(cw) do { short tmp = (cw); __asm { fclex }; __asm { fldcw tmp }; } while (0)
